# =============================================================================
# .env.example — Mẫu cấu hình môi trường
# Copy file này thành .env và chỉnh sửa giá trị cho phù hợp
#   cp .env.example .env
# =============================================================================

# Database (SQLite)
# Dùng relative path cho môi trường dev local:
DATABASE_URL="file:./db/custom.db"
#
# Trong Docker, path này sẽ bị override bởi biến trong docker-compose.yml:
#   DATABASE_URL=file:/app/data/custom.db
# (thư mục /app/data được mount thành volume để giữ dữ liệu persistent)

# Auto-seed dữ liệu mẫu
# - "true":  Tự động seed dữ liệu mẫu khi load trang (CHỈ dùng cho dev/demo)
# - "false": Tắt (mặc định cho production)
NEXT_PUBLIC_AUTO_SEED="false"
