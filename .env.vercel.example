# =============================================================================
# .env.vercel.example — Biến môi trường cần set trong Vercel Dashboard
#
# Cách set: Vercel Dashboard → Project → Settings → Environment Variables
# =============================================================================

# DATABASE_URL — Neon PostgreSQL connection string
# Lấy từ: Neon Dashboard → project → "Connection string"
# Đảm bảo connection string kết thúc bằng ?sslmode=require
#
# Ví dụ:
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Tắt auto-seed ở production (KHÔNG tự động insert data mẫu)
NEXT_PUBLIC_AUTO_SEED=false

# Bắt buộc nếu cần gọi /api/seed thủ công (dev/local):
# SEED_SECRET=<random-string>
