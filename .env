# =============================================================================
# Environment Configuration
# =============================================================================

# DATABASE_URL — có 3 kịch bản:
#
# 1) Local DEV với Neon Postgres (khuyến nghị khi phát triển tính năng Vercel):
#    DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
#
# 2) Local DEV với SQLite (legacy — không dùng được cho Vercel):
#    DATABASE_URL="file:./db/custom.db"
#
# 3) Production (Vercel/Oracle Cloud) — set trong Vercel Dashboard hoặc docker-compose.yml
#
# Mặc định: dùng Neon Postgres (thay connection string của bạn vào)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Auto-seed dữ liệu mẫu
# - "true":  Tự động seed dữ liệu mẫu khi load trang (CHỈ dùng cho dev/demo)
# - "false": Tắt (mặc định cho production)
NEXT_PUBLIC_AUTO_SEED="false"
